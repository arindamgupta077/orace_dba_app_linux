        "jsCode": "const item=$input.first().json;const h={};for(const [k,v] of Object.entries(item.headers||{})){h[k.toLowerCase()]=Array.isArray(v)?String(v[0]||''):String(v||'');}const expected=$env.ADMIN_WEBHOOK_SECRET||'replace-with-strong-shared-secret';const provided=h['x-admin-webhook-secret']||'';if(!expected||provided!==expected){return [{json:{route:'error',success:false,message:'Unauthorized.'}}];}const body=item.body&&typeof item.body==='object'?item.body:item;const fwd=String(h['x-forwarded-for']||'').split(',')[0].trim();return [{json:{route:String(body.flow||'').trim(),email:body.email,token:body.token,newPassword:body.newPassword,requestIp:String(body.requestIp||fwd||h['x-real-ip']||'unknown').slice(0,64),userAgent:String(body.userAgent||h['user-agent']||'unknown').slice(0,512)}}];"
