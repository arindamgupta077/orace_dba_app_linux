        "jsCode": "const crypto=require('crypto');const failure={success:false,message:'Invalid or expired reset link.'};function sqlString(v,n){return String(v||'').slice(0,n).replace(/'/g,\"''\");}function weak(p){return p.length<12||!/[a-z]/.test(p)||!/[A-Z]/.test(p)||!/[0-9]/.test(p)||!/[^A-Za-z0-9]/.test(p);}const token=String($json.token||'').trim();const newPassword=String($json.newPassword||'');const requestIp=String($json.requestIp||'unknown').slice(0,64);const userAgent=String($json.userAgent||'unknown').slice(0,512);if(token.length<32||token.length>512||weak(newPassword)){return [{json:{shouldQuery:false,...failure}}];}const tokenHash=crypto.createHash('sha256').update(token,'utf8').digest('hex');const newSalt=crypto.randomBytes(32).toString('hex');const newPasswordHash=crypto.createHash('sha256').update(`${newSalt}:${newPassword}`,'utf8').digest('hex');const oracleSql=\"SELECT app_auth_reset_pkg.reset_password_json(p_token_hash => '\"+tokenHash+\"', p_new_salt => '\"+newSalt+\"', p_new_password_hash => '\"+newPasswordHash+\"', p_request_ip => '\"+sqlString(requestIp,64)+\"', p_user_agent => '\"+sqlString(userAgent,512)+\"') AS result_json FROM dual\";return [{json:{shouldQuery:true,oracleSql}}];"
