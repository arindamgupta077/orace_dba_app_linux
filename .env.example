# Oracle app database (auth, audit, history) — reachable from the RHEL app host
ORACLE_CONNECTION_STRING=localhost:1521/ORCL
ORACLE_USER=APP_DBA
ORACLE_PASSWORD=Password123
APP_AUTH_SECRET=change-this-long-random-secret
APP_SESSION_COOKIE_NAME=dba_session
APP_SESSION_TTL_HOURS=8
APP_SESSION_REMEMBER_TTL_DAYS=30

# n8n webhook on the same RHEL server (or reachable URL)
NEXT_PUBLIC_DBA_WEBHOOK_URL=http://localhost:5678/webhook/dba-agent
NEXT_PUBLIC_DBA_TOKEN=replace-with-api-token
NEXT_PUBLIC_DBA_MOCK=false
NEXT_PUBLIC_DBA_WS_URL=
NEXT_PUBLIC_DEFAULT_DB=ORCL

# n8n password reset webhook. Keep ADMIN_WEBHOOK_SECRET server-side only.
NEXT_PUBLIC_ADMIN_WEBHOOK_URL=http://localhost:5678/webhook-test/f9c3cdfb-4e5d-4754-92e5-4ff77c472077
ADMIN_WEBHOOK_SECRET=replace-with-strong-shared-secret

# Copy this file to .env.local on the server before npm run build:
#   cp .env.example .env.local
